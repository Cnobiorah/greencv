{
  "functions": {
    "api/analyze.js":       { "maxDuration": 60 },
    "api/analyze-image.js": { "maxDuration": 60 },
    "api/job-match.js":     { "maxDuration": 60 },
    "api/cover-letter.js":  { "maxDuration": 60 },
    "api/linkedin.js":      { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/analyze",        "destination": "/api/analyze" },
    { "source": "/analyze-image",  "destination": "/api/analyze-image" },
    { "source": "/job-match",      "destination": "/api/job-match" },
    { "source": "/cover-letter",   "destination": "/api/cover-letter" },
    { "source": "/linkedin",       "destination": "/api/linkedin" },
    { "source": "/send-email",     "destination": "/api/send-email" },
    { "source": "/send-feedback",  "destination": "/api/send-feedback" },
    { "source": "/get-feedback",   "destination": "/api/get-feedback" },
    { "source": "/admin-data",     "destination": "/api/admin" },
    { "source": "/ping",           "destination": "/api/ping" },
    { "source": "/admin",          "destination": "/admin.html" },
    { "source": "/app",            "destination": "/app.html" },
    { "source": "/",               "destination": "/index.html" }
  ]
}
